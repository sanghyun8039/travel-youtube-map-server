generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Channel {
  id           String   @id @default(uuid())
  channelId    String   @unique
  channelName  String
  channelUrl   String
  thumbnailUrl String?
  createdAt    DateTime @default(now())

  videos       Video[]
}

model Video {
  id          String   @id @default(uuid())
  videoId     String   @unique
  title       String
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id])
  destCity    String?
  destCountry String?
  analyzedAt  DateTime @default(now())

  places      VideoPlace[]
  savedVideos SavedVideo[]
}

model Place {
  id            String   @id @default(uuid())
  googlePlaceId String   @unique
  name          String
  address       String?
  city          String?
  country       String?
  countryCode   String?
  lat           Float
  lng           Float
  category      String?
  createdAt     DateTime @default(now())

  appearances   VideoPlace[]
  favoritePlaces FavoritePlace[]
  coursePlaces   CoursePlace[]
}

model VideoPlace {
  id          String   @id @default(uuid())
  videoId     String
  video       Video    @relation(fields: [videoId], references: [id])
  placeId     String?
  place       Place?   @relation(fields: [placeId], references: [id])
  timestamp   Int
  localName   String
  description String?
  orderIndex  Int

  @@unique([videoId, orderIndex])
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  name         String?
  refreshToken String?  @unique
  signupSource String?  // "kakao", "naver", "google"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  socialAccounts SocialAccount[]
  favoritePlaces FavoritePlace[]
  savedVideos    SavedVideo[]
  courses        Course[]
}

model SocialAccount {
  id         String   @id @default(uuid())
  provider   String   // "kakao", "naver", "google"
  providerId String   // Provider's unique user ID
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
}

model FavoritePlace {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id])
  memo      String?
  createdAt DateTime @default(now())

  @@unique([userId, placeId])
}

model SavedVideo {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
}

model Course {
  id        String        @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  places    CoursePlace[]
}

model CoursePlace {
  id         String   @id @default(uuid())
  courseId   String
  placeId    String
  orderIndex Int
  createdAt  DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  place      Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([courseId, placeId])
  @@index([placeId])
}
